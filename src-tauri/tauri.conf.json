{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZCode Switcher",
  "version": "1.1.7",
  "identifier": "com.zcode.switcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ZCode Switcher",
        "width": 680,
        "height": 720,
        "minWidth": 560,
        "minHeight": 560,
        "resizable": true,
        "transparent": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJDRDU0MzlEOUFBNEFEMgpSV1RTU3FyWk9WVE5BclBIM1VtM3RaZzcydElSR3U5UE42blZ2QlBlc1lRTy96Zk9qQUdhbU9sVgo=",
      "endpoints": [
        "https://github.com/git-l-1031/zcode-switcher/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
